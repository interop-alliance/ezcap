{
  "name": "@interop/ezcap",
  "description": "An easy-to-use, opinionated Authorization Capabilities (zcap) client for the browser and Node.js.",
  "version": "7.3.1",
  "type": "module",
  "scripts": {
    "build": "pnpm run clear && tsc",
    "clear": "rimraf dist/*",
    "dev": "vite",
    "fix": "eslint --fix src test && pnpm run format",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint src test",
    "prepare": "pnpm run build",
    "rebuild": "pnpm run clear && pnpm run build",
    "test": "pnpm run lint && pnpm run test-node && pnpm run test-browser",
    "test-browser": "playwright test",
    "test-node": "vitest run",
    "test-perf": "PERF=1 vitest run test/node/delegate.perf.test.ts --disableConsoleIntercept",
    "test-coverage": "vitest run --coverage"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "module": "dist/index.js",
  "browser": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "dependencies": {
    "@interop/data-integrity-core": "^8.1.0",
    "@interop/data-integrity-proof": "^3.4.1",
    "@interop/ecdsa-signature": "^2.0.3",
    "@interop/http-client": "^1.0.4",
    "@interop/http-signature-zcap-invoke": "^6.2.3",
    "@interop/jsonld-signatures": "^11.8.2",
    "@interop/zcap": "^11.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@interop/did-method-key": "^7.3.3",
    "@interop/ed25519-signature": "^7.1.2",
    "@interop/ed25519-verification-key": "^8.0.2",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "zcap",
    "authorization-capabilities",
    "decentralized",
    "linked-data",
    "isomorphic"
  ],
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=20.0"
  },
  "author": {
    "name": "Digital Bazaar, Inc.",
    "email": "support@digitalbazaar.com",
    "url": "https://digitalbazaar.com/"
  },
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/interop-alliance/ezcap.git"
  },
  "homepage": "https://github.com/interop-alliance/ezcap",
  "bugs": "https://github.com/interop-alliance/ezcap/issues"
}
