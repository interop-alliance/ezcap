{
  "name": "@interop/ezcap",
  "description": "An easy-to-use, opinionated Authorization Capabilities (zcap) client for the browser and Node.js.",
  "version": "7.0.1",
  "type": "module",
  "scripts": {
    "build": "pnpm run clear && tsc",
    "clear": "rimraf dist/*",
    "dev": "vite",
    "fix": "eslint --fix src test && pnpm run format",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint src test",
    "prepare": "pnpm run build",
    "rebuild": "pnpm run clear && pnpm run build",
    "test": "pnpm run lint && pnpm run test-node && pnpm run test-browser",
    "test-browser": "playwright test",
    "test-node": "vitest run",
    "test-coverage": "vitest run --coverage"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "module": "dist/index.js",
  "browser": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "dependencies": {
    "@interop/http-client": "^1.0.3",
    "@interop/http-signature-zcap-invoke": "^6.1.2",
    "@interop/jsonld-signatures": "^11.6.2",
    "@interop/zcap": "^9.0.3",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@interop/did-method-key": "^6.2.1",
    "@interop/ed25519-signature": "^6.0.1",
    "@interop/ed25519-verification-key": "^6.2.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "zcap",
    "authorization-capabilities",
    "decentralized",
    "linked-data",
    "isomorphic"
  ],
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=20.0"
  },
  "author": {
    "name": "Interop Alliance",
    "url": "https://github.com/interop-alliance/"
  },
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/interop-alliance/ezcap.git"
  },
  "homepage": "https://github.com/interop-alliance/ezcap",
  "bugs": "https://github.com/interop-alliance/ezcap/issues"
}
